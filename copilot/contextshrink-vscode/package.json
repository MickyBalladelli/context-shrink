{
  "name": "contextshrink-vscode",
  "displayName": "ContextShrink",
  "description": "ContextShrink XML for GitHub Copilot Chat and Codex.",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "icon": "images/context-shrink.png",
  "repository": {
    "type": "git",
    "url": "file:../.."
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:contextshrink.generateContext",
    "onCommand:contextshrink.generateAndAsk",
    "onCommand:contextshrink.copyContext",
    "onCommand:contextshrink.copyProjectMap",
    "onCommand:contextshrink.previewProjectMap",
    "onCommand:contextshrink.openContext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextshrink.generateContext",
        "title": "ContextShrink: Generate Context"
      },
      {
        "command": "contextshrink.generateAndAsk",
        "title": "ContextShrink: Generate and Ask"
      },
      {
        "command": "contextshrink.copyContext",
        "title": "ContextShrink: Copy Context Prompt"
      },
      {
        "command": "contextshrink.copyProjectMap",
        "title": "ContextShrink: Copy Project Map"
      },
      {
        "command": "contextshrink.previewProjectMap",
        "title": "ContextShrink: Preview Project Map"
      },
      {
        "command": "contextshrink.openContext",
        "title": "ContextShrink: Open Last Context"
      }
    ],
    "configuration": {
      "title": "ContextShrink",
      "properties": {
        "contextshrink.maxTokens": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Token budget for generated Copilot context."
        },
        "contextshrink.level": {
          "type": "number",
          "default": 2,
          "enum": [
            1,
            2,
            3
          ],
          "description": "Compression level: 1 full-first, 2 skeleton, 3 tree map."
        },
        "contextshrink.outputFile": {
          "type": "string",
          "default": "/tmp/contextshrink-vscode.xml",
          "description": "File path where generated context is written."
        },
        "contextshrink.outputFormat": {
          "type": "string",
          "default": "xml",
          "enum": [
            "xml",
            "json"
          ],
          "description": "Generated context format."
        },
        "contextshrink.include": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns to include, such as src/**."
        },
        "contextshrink.exclude": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns to exclude, such as **/generated/**."
        },
        "contextshrink.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Respect .gitignore, global gitignore, and git exclude files."
        },
        "contextshrink.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Optional explicit path to the contextshrink binary. When empty, ContextShrink checks CONTEXTSHRINK_BIN, PATH, then local release builds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node dist/contextshrink.smoke.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.4.5"
  }
}
